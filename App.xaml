<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestionTaches.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackgroundColor">#F4F8FB</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#0F766E</Color>
            <Color x:Key="PrimaryDarkColor">#115E59</Color>
            <Color x:Key="DangerColor">#BE123C</Color>
            <Color x:Key="BorderColor">#DCE3ED</Color>
            <Color x:Key="MutedTextColor">#4A5E77</Color>
            <Color x:Key="HeadingColor">#0F2E4F</Color>
            <Color x:Key="SuccessSoftColor">#EEFDF3</Color>
            <Color x:Key="WarningSoftColor">#FFF7EC</Color>
            <Color x:Key="DangerSoftColor">#FFF0F0</Color>
            <Color x:Key="InfoSoftColor">#F1F8FF</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{StaticResource PageBackgroundColor}" />
            </Style>

            <Style TargetType="Border">
                <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="#1B2D42" />
                <Setter Property="PlaceholderColor" Value="#7B8CA5" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="#1B2D42" />
                <Setter Property="PlaceholderColor" Value="#7B8CA5" />
                <Setter Property="AutoSize" Value="TextChanges" />
                <Setter Property="MinimumHeightRequest" Value="110" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TitleColor" Value="#7B8CA5" />
                <Setter Property="TextColor" Value="#1B2D42" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>

            <Style TargetType="DatePicker">
                <Setter Property="TextColor" Value="#1B2D42" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="#1B2D42" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="MinimumHeightRequest" Value="44" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
