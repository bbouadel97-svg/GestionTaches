<Window x:Class="GestionTaches.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GestionTaches.Models"
        mc:Ignorable="d"
        Title="Gestion des taches" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE3ED" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentBrushHover" Color="#115E59" />

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#C9D3E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FAFCFF" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#C9D3E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FAFCFF" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="#C9D3E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FAFCFF" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentBrushHover}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E7EFFA" />
            <Setter Property="Foreground" Value="#1E3A5F" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#D2DEEE" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="KanbanCardBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D8E2EE" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Priorite}" Value="{x:Static models:PrioriteTache.Critique}">
                    <Setter Property="Background" Value="#FFF1F1" />
                    <Setter Property="BorderBrush" Value="#F5BCBC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Priorite}" Value="{x:Static models:PrioriteTache.Haute}">
                    <Setter Property="Background" Value="#FFF8EE" />
                    <Setter Property="BorderBrush" Value="#F0D3A6" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Priorite}" Value="{x:Static models:PrioriteTache.Basse}">
                    <Setter Property="Background" Value="#F2FAF7" />
                    <Setter Property="BorderBrush" Value="#CDE9DB" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="KanbanCardTemplate">
            <Border Style="{StaticResource KanbanCardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding Titre}" FontWeight="SemiBold" Foreground="#1A3556" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Assignee, StringFormat=Assigne: {0}}" Margin="0,6,0,0" Foreground="#425C79" />
                    <TextBlock Text="{Binding Priorite, StringFormat=Priorite: {0}}" Foreground="#425C79" />
                    <TextBlock Text="{Binding DateEcheance, StringFormat=Echeance: {0}}" Foreground="#425C79" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F5FAFF" Offset="0" />
                <GradientStop Color="#EEF6F4" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrushSoft}" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="14" Margin="0,0,12,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#220A2540" />
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Nouvelle tache" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="#0F2E4F" />
                <TextBlock Text="Ajoutez, modifiez et priorisez rapidement vos actions." Foreground="#4A5E77" Margin="0,0,0,14" />

                <TextBlock Text="Titre" FontWeight="SemiBold" Foreground="#274666" />
                <TextBox x:Name="TitreTextBox" Margin="0,4,0,10" />

                <TextBlock Text="Description" FontWeight="SemiBold" Foreground="#274666" />
                <TextBox x:Name="DescriptionTextBox" Margin="0,4,0,10" Height="90" TextWrapping="Wrap" AcceptsReturn="True" />

                <TextBlock Text="Assigne a" FontWeight="SemiBold" Foreground="#274666" />
                <TextBox x:Name="AssigneeTextBox" Margin="0,4,0,10" />

                <TextBlock Text="Priorite" FontWeight="SemiBold" Foreground="#274666" />
                <ComboBox x:Name="PrioriteComboBox" Margin="0,4,0,10" />

                <TextBlock Text="Statut" FontWeight="SemiBold" Foreground="#274666" />
                <ComboBox x:Name="StatutComboBox" Margin="0,4,0,10" />

                <TextBlock Text="Date d'echeance" FontWeight="SemiBold" Foreground="#274666" />
                <DatePicker x:Name="DateEcheancePicker" Margin="0,4,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Ajouter" Width="90" Margin="0,0,8,0" Click="Ajouter_Click" />
                    <Button Content="Modifier" Width="90" Margin="0,0,8,0" Click="Modifier_Click" />
                    <Button Content="Supprimer" Width="90" Click="Supprimer_Click" />
                </StackPanel>

                <TextBlock x:Name="MessageTextBlock" Margin="0,12,0,0" Foreground="#0B6" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" BorderThickness="1" BorderBrush="{StaticResource BorderBrushSoft}" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Color="#220A2540" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Text="Liste des taches" FontSize="22" FontWeight="SemiBold" Foreground="#0F2E4F" />
                    <TextBlock x:Name="HorlogeTextBlock" DockPanel.Dock="Right" Foreground="#516885" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>

                <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,10">
                    <Border Margin="0,0,8,0" Background="#F1F8FF" BorderBrush="#D7E8FC" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Total" Foreground="#3A5575" />
                            <TextBlock x:Name="TotalTextBlock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#0E355C" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Background="#EEFDF3" BorderBrush="#D0F2DD" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="A faire" Foreground="#355E48" />
                            <TextBlock x:Name="AFaireTextBlock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#1F6A46" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,8,0" Background="#FFF7EC" BorderBrush="#FADFB8" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="En cours" Foreground="#70522A" />
                            <TextBlock x:Name="EnCoursTextBlock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#9A6112" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF0F0" BorderBrush="#F8D0D0" BorderThickness="1" CornerRadius="10" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Bloquees" Foreground="#6A3D3D" />
                            <TextBlock x:Name="BloqueesTextBlock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#A43535" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBox x:Name="RechercheTextBox" Width="220" Margin="0,0,8,0" VerticalContentAlignment="Center" TextChanged="Filtres_Changed" />
                    <ComboBox x:Name="FiltreStatutComboBox" Width="180" SelectionChanged="Filtres_Changed" />
                    <ComboBox x:Name="FiltrePrioriteComboBox" Width="160" Margin="8,0,0,0" SelectionChanged="Filtres_Changed" />
                    <TextBox x:Name="FiltreAssigneeTextBox" Width="180" Margin="8,0,0,0" VerticalContentAlignment="Center" TextChanged="Filtres_Changed" />
                    <TextBlock x:Name="ResultatsTextBlock" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#4D617A" FontWeight="SemiBold" />
                </WrapPanel>

                <TabControl Grid.Row="3">
                    <TabItem Header="Tableau">
                        <DataGrid x:Name="TachesDataGrid"
                                  AutoGenerateColumns="False"
                                  AlternationCount="2"
                                  RowBackground="#FFFFFF"
                                  AlternatingRowBackground="#F8FBFF"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#E6EEF8"
                                  VerticalGridLinesBrush="#EEF3FA"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="TachesDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Titre" Binding="{Binding Titre}" Width="2*" />
                                <DataGridTextColumn Header="Assigne" Binding="{Binding Assignee}" Width="*" />
                                <DataGridTextColumn Header="Priorite" Binding="{Binding Priorite}" Width="*" />
                                <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="*" />
                                <DataGridTextColumn Header="Echeance" Binding="{Binding DateEcheance}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Kanban">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,8,0" Background="#F3F9FF" BorderBrush="#D7E7FA" BorderThickness="1" CornerRadius="10" Padding="8">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="A faire" FontWeight="SemiBold" Foreground="#20486E" Margin="0,0,0,8" />
                                    <ListBox x:Name="KanbanAFaireListBox" Background="Transparent" BorderThickness="0" ItemTemplate="{StaticResource KanbanCardTemplate}" SelectionChanged="KanbanList_SelectionChanged" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="0,0,8,0" Background="#F6FCEF" BorderBrush="#D8EDC8" BorderThickness="1" CornerRadius="10" Padding="8">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="En cours" FontWeight="SemiBold" Foreground="#2E5C39" Margin="0,0,0,8" />
                                    <ListBox x:Name="KanbanEnCoursListBox" Background="Transparent" BorderThickness="0" ItemTemplate="{StaticResource KanbanCardTemplate}" SelectionChanged="KanbanList_SelectionChanged" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="0,0,8,0" Background="#FFF8EE" BorderBrush="#F1E0C4" BorderThickness="1" CornerRadius="10" Padding="8">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Bloquees" FontWeight="SemiBold" Foreground="#6D5128" Margin="0,0,0,8" />
                                    <ListBox x:Name="KanbanBloqueesListBox" Background="Transparent" BorderThickness="0" ItemTemplate="{StaticResource KanbanCardTemplate}" SelectionChanged="KanbanList_SelectionChanged" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="3" Background="#F2FBF7" BorderBrush="#D0EBDD" BorderThickness="1" CornerRadius="10" Padding="8">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Terminees" FontWeight="SemiBold" Foreground="#1F5E47" Margin="0,0,0,8" />
                                    <ListBox x:Name="KanbanTermineesListBox" Background="Transparent" BorderThickness="0" ItemTemplate="{StaticResource KanbanCardTemplate}" SelectionChanged="KanbanList_SelectionChanged" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>
